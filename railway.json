{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile",
    "watchPatterns": [
      "backend/**"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 3,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "envVars": {
      "PORT": {
        "value": "8000"
      },
      "ENVIRONMENT": {
        "value": "production"
      }
    }
  },
  "environments": {
    "production": {
      "build": {
        "context": "backend"
      }
    }
  }
}